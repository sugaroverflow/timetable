# ---------------------------------------------------------------------------
# Timetable — environment variables
# Copy to `.env` (root) for local dev. Each app reads what it needs.
# ---------------------------------------------------------------------------

# Postgres (local dev uses docker-compose; prod uses DigitalOcean Managed PG)
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://timetable:timetable@localhost:5432/timetable
# DigitalOcean Managed PG requires TLS. Set to "require" in prod.
DATABASE_SSL=disable

# --- API (apps/api) ---
API_PORT=4000
# Comma-separated list of allowed browser origins for CORS.
WEB_ORIGIN=http://localhost:3000

# --- Web (apps/web) ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql

# --- Clerk (authentication) ---
# From the Clerk dashboard (API Keys). The API verifies session tokens with the
# secret key; the web app uses both.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/timetables
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/timetables

# Email digests (Phase 4). Optional in dev — without RESEND_API_KEY, digest
# emails are logged to the API console instead of sent.
RESEND_API_KEY=
EMAIL_FROM="Timetable <no-reply@example.com>"
# Shared secret for the digest cron endpoint (POST /api/jobs/digests).
CRON_SECRET=replace-me

# --- Object storage (DigitalOcean Spaces, S3-compatible) — used from Phase 1 ---
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_REGION=nyc3
SPACES_BUCKET=timetable-uploads
SPACES_KEY=
SPACES_SECRET=
