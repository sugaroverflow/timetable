# ---------------------------------------------------------------------------
# Timetable — environment variables (LOCAL DEV)
#
# Copy to:
#   .env                 — API + DB tooling (root)
#   apps/web/.env.local  — Next.js web app (all NEXT_PUBLIC_* go here)
#
# Hosted dev (dev.timetable.love) and production (timetable.love) use GitHub
# Environment secrets — not these files. See README § Environments.
# ---------------------------------------------------------------------------

# Postgres (local dev uses docker-compose; hosted apps use DigitalOcean Managed PG)
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://timetable:timetable@localhost:5432/timetable
# DigitalOcean Managed PG requires TLS. Set to "require" on hosted apps.
DATABASE_SSL=disable

# --- API (apps/api) ---
API_PORT=4000
# Comma-separated list of allowed browser origins for CORS.
WEB_ORIGIN=http://localhost:3000
# Optional API hardening knobs.
TRUST_PROXY_HOPS=1
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
GRAPHQL_MAX_DEPTH=12
GRAPHQL_MAX_COST=500

# --- Web (apps/web) — copy these into apps/web/.env.local ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql
# Server-side route lookup URL used by custom-domain middleware.
GRAPHQL_ROUTE_URL=http://localhost:4000/graphql
# Comma-separated hostnames that should not be treated as timetable custom domains.
NEXT_PUBLIC_CANONICAL_HOSTS=localhost,timetable.love,dev.timetable.love

# --- Clerk (authentication) ---
# Local + hosted dev: Clerk **Development** keys (pk_test_ / sk_test_).
# Production (timetable.love): pk_live_ / sk_live_ in GitHub Environment "production".
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/timetables
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/timetables

# Email digests (Phase 4). Optional in dev — without RESEND_API_KEY, digest
# emails are logged to the API console instead of sent.
RESEND_API_KEY=
EMAIL_FROM="Timetable <no-reply@example.com>"
# Shared secret for the digest cron endpoint (POST /api/jobs/digests).
CRON_SECRET=replace-me

# --- Object storage (DigitalOcean Spaces, S3-compatible) ---
# Optional locally. Without SPACES_*, /api/uploads returns 503.
#
# Recommended hosted setup: separate buckets per environment
#   timetable-dev  →  dev app + local (if you test uploads)
#   timetable      →  production app only
# Set SPACES_* in the DO console on each app's api component (not in GitHub).
SPACES_ENDPOINT=https://lon1.digitaloceanspaces.com
SPACES_REGION=lon1
SPACES_BUCKET=timetable-dev
SPACES_KEY=
SPACES_SECRET=
# Optional CDN/custom domain for public URLs:
# SPACES_PUBLIC_BASE_URL=
